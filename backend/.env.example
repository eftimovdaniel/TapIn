# Supabase connection (kopiraj vo .env i popolni)
DATABASE_URL=postgresql+psycopg://postgres.YOUR_REF:YOUR_PASSWORD@aws-1-eu-central-1.pooler.supabase.com:5432/postgres

# JWT secret (generiraj: python -c "import secrets; print(secrets.token_urlsafe(48))")
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_TTL_HOURS=24

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:3000,http://localhost:8000,http://127.0.0.1:8000

PORT=8080
